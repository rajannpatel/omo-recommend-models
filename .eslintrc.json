{
  "root": true,
  "env": {
    "node": true,
    "es6": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["error", {
      "argsIgnorePattern": "^_",
      "caughtErrorsIgnorePattern": "^_"
    }],
    "no-undef": "error",
    "no-empty": ["error", {
      "allowEmptyCatch": true
    }],
    "no-duplicate-imports": "error",
    "no-useless-catch": "warn"
  }
}

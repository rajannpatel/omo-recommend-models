// Wrapper that injects monolith-local dependency functions into extracted defaultPanelModels
function defaultPanelModels(config, cloudLookup = null, options = {}) {
  return defaultPanelModelsImpl(config, cloudLookup, {
    ...options,
    _discoverFreeModels: discoverFreeModels,
    _preferDetectedCliPanelModels: (refs, cfg, cl, max, opts) => {
      const discoverFn = (cfg2, opts2) => discoverCliModelsImpl(cfg2, opts2, ctx, commandExists);
      return preferDetectedCliPanelModelsImpl(refs, cfg, cl, max, opts, discoverFn, ctx);
    },
  });
}

function discoverFreeModels(options = {}) {
  if (options.noFreePanel) {
    return [];
  }
  return originalDiscoverFreeModels();
}

const runtime = createCliRuntime();
const { ctx, subprocess } = runtime;

function terminateActiveChildren() {
  runtime.terminateActiveChildren();
}

function installSignalHandlers() {
  runtime.installSignalHandlers();
}

async function configureTerminalUi(enabled) {
  await runtime.configureTerminalUi(enabled);
}

async function confirm(question) {
  return runtime.confirm(question);
}

async function promptUser(question) {
  return runtime.promptUser(question);
}

function commandExists(binary) {
  if (!binary || binary.includes(path.sep)) return "";
  for (const dir of String(process.env.PATH || "").split(path.delimiter)) {
    if (!dir) continue;
    const candidate = path.join(dir, binary);
    try {
      const stat = fs.statSync(candidate);
      if (!stat.isFile()) continue;
      fs.accessSync(candidate, fs.constants.X_OK);
      return candidate;
    } catch {}
  }
  return "";
}





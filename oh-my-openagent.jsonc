        "opencode/big-pickle"
      ]
    },
    "sisyphus-junior": {
      "description": "Focused task executor under orchestration",
      "model": "opencode/big-pickle",
      "fallback_models": [
        "opencode/nemotron-3-ultra-free",
        "opencode/deepseek-v4-flash-free",
        "opencode/north-mini-code-free",
        "opencode/mimo-v2.5-free"
      ]
    },
    "scout": {
      "description": "Fast context gathering and file search",
      "model": "opencode/nemotron-3-ultra-free"
    },
    "sysadmin": {
      "description": "Scripting, automation, and system configuration",
      "model": "opencode/nemotron-3-ultra-free"
    }
  },
  "categories": {

        "opencode/deepseek-v4-flash-free",
        "opencode/north-mini-code-free",
        "opencode/big-pickle"
      ]
    }
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },"team_mode": {"enabled":true,"max_parallel_members":4,"max_members":8,"tmux_visualization":false}
}

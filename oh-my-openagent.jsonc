{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "runtime_fallback": true,
  "agents": {
    "sisyphus": {
      "description": "Primary orchestrator and architectural planner",
      "model": "opencode/big-pickle",
      "fallback_models": [
        "opencode/nemotron-3-ultra-free",
        "opencode/deepseek-v4-flash-free",
        "opencode/north-mini-code-free",
        "opencode/mimo-v2.5-free"
      ]
    },
    "hephaestus": {
      "description": "Autonomous deep worker for writing large code files and refactoring",
      "model": "opencode/mimo-v2.5-free",
      "fallback_models": [
        "opencode/nemotron-3-ultra-free",
        "opencode/deepseek-v4-flash-free",
        "opencode/north-mini-code-free",
        "opencode/big-pickle",
        "local/codellama:7b"
      ]
    },
    "oracle": {
      "description": "High-IQ consultation agent for complex architecture and debugging",
      "model": "opencode/mimo-v2.5-free",
      "fallback_models": [
        "opencode/nemotron-3-ultra-free",
        "opencode/deepseek-v4-flash-free",
        "opencode/north-mini-code-free",
        "opencode/big-pickle"
      ]
    },
    "librarian": {
      "description": "Reads local documentation, markdown files, and generates summaries",
      "model": "opencode/mimo-v2.5-free",
      "fallback_models": [
        "opencode/nemotron-3-ultra-free",
        "opencode/deepseek-v4-flash-free",
        "opencode/north-mini-code-free",
        "opencode/big-pickle"
      ]
    },
    "explore": {
      "description": "Fast codebase exploration and pattern matching",
      "model": "opencode/mimo-v2.5-free",
      "fallback_models": [
        "opencode/nemotron-3-ultra-free",
        "opencode/deepseek-v4-flash-free",
        "opencode/north-mini-code-free",
        "opencode/big-pickle"
      ]
    },
    "multimodal-looker": {
      "description": "Analyzes images, PDFs, and other media files",
      "model": "opencode/mimo-v2.5-free",
      "fallback_models": [
        "opencode/nemotron-3-ultra-free",
        "opencode/deepseek-v4-flash-free",
        "opencode/north-mini-code-free",
        "opencode/big-pickle"
      ]
    },
    "prometheus": {
      "description": "Generates, runs, and evaluates comprehensive unit tests",
      "model": "opencode/mimo-v2.5-free",
      "fallback_models": [
        "opencode/nemotron-3-ultra-free",
        "opencode/deepseek-v4-flash-free",
        "opencode/north-mini-code-free",
        "opencode/big-pickle",
        "local/codellama:7b"
      ]
    },
    "metis": {
      "description": "Pre-planning consultant for ambiguous requirements",
      "model": "opencode/mimo-v2.5-free",
      "fallback_models": [
        "opencode/nemotron-3-ultra-free",
        "opencode/deepseek-v4-flash-free",
        "opencode/north-mini-code-free",
        "opencode/big-pickle"
      ]
    },
    "momus": {
      "description": "Expert reviewer for work plans and quality assurance",
      "model": "opencode/mimo-v2.5-free",
      "fallback_models": [
        "opencode/nemotron-3-ultra-free",
        "opencode/deepseek-v4-flash-free",
        "opencode/north-mini-code-free",
        "opencode/big-pickle"
      ]
